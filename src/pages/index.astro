---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("nb-NO", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base title="Klipperhotell" description="Vi lagrer din robotklipper - en del av Mortenshage.no">
	{posts.length === 0 ? (
		<section class="empty-state">
			<h2>Ingen innlegg ennå</h2>
			<p>Opprett ditt første innlegg i admin-panelet.</p>
			<a href="/_emdash/admin/content/posts/new" class="btn">Opprett innlegg</a>
		</section>
	) : (
		<div class="posts-listing">
			{sortedPosts.map((post) => (
				<article class="post-entry">
					{post.data.featured_image && (
						<a href={`/posts/${post.id}`} class="post-thumbnail">
							<Image image={post.data.featured_image} />
						</a>
					)}
					<div class="post-content">
						<h2 class="post-title">
							<a href={`/posts/${post.id}`}>{post.data.title}</a>
						</h2>
						<div class="post-meta">
							{formatDate(post.data.publishedAt) && (
								<time>{formatDate(post.data.publishedAt)}</time>
							)}
						</div>
						{post.data.excerpt && (
							<p class="post-excerpt">{post.data.excerpt}</p>
						)}
						<a href={`/posts/${post.id}`} class="read-more">Les mer &raquo;</a>
					</div>
				</article>
			))}
		</div>
	)}
</Base>

<style>
	.posts-listing {
		max-width: 800px;
	}

	.post-entry {
		display: flex;
		gap: 1.5rem;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.post-entry:first-child {
		padding-top: 0;
	}

	.post-entry:last-child {
		border-bottom: none;
	}

	.post-thumbnail {
		flex-shrink: 0;
		width: 250px;
		display: block;
	}

	.post-thumbnail img {
		width: 100%;
		height: auto;
		display: block;
	}

	.post-content {
		flex: 1;
		min-width: 0;
	}

	.post-title {
		font-size: var(--font-size-2xl);
		font-weight: 700;
		margin-bottom: 0.5rem;
		line-height: 1.3;
	}

	.post-title a {
		color: var(--color-heading);
		text-decoration: none;
	}

	.post-title a:hover {
		color: var(--color-accent);
	}

	.post-meta {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: 0.75rem;
	}

	.post-excerpt {
		color: var(--color-text);
		line-height: 1.7;
		margin-bottom: 0.75rem;
	}

	.read-more {
		display: inline-block;
		padding: 0.4rem 1.2rem;
		background: var(--color-accent);
		color: white !important;
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-decoration: none;
		transition: background 0.2s;
	}

	.read-more:hover {
		background: var(--color-accent-hover);
		color: white !important;
	}

	.empty-state {
		text-align: center;
		padding: 4rem 1rem;
	}

	.empty-state h2 {
		font-size: var(--font-size-2xl);
		margin-bottom: 0.5rem;
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: 1rem;
	}

	.btn {
		display: inline-block;
		padding: 0.5rem 1.5rem;
		background: var(--color-accent);
		color: white;
		text-decoration: none;
		font-weight: 700;
	}

	@media (max-width: 600px) {
		.post-entry {
			flex-direction: column;
		}

		.post-thumbnail {
			width: 100%;
		}
	}
</style>
