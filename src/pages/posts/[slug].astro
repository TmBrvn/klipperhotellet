---
import {
	getEmDashEntry,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);

const seo = getSeoMeta(post, {
	siteTitle: "Klipperhotell",
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category");

const publishDate =
	post.data.publishedAt?.toLocaleDateString("nb-NO", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
	sidebar
>
	<article class="article">
		<header class="article-header">
			<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
			<div class="article-meta">
				{publishDate && <time>{publishDate}</time>}
				{categories.length > 0 && (
					<>
						<span class="meta-sep">|</span>
						{categories.map((cat, i) => (
							<>
								{i > 0 && <span>, </span>}
								<a href={`/category/${cat.slug}`}>{cat.label}</a>
							</>
						))}
					</>
				)}
				{tags.length > 0 && (
					<>
						<span class="meta-sep">|</span>
						{tags.map((tag, i) => (
							<>
								{i > 0 && <span>, </span>}
								<a href={`/tag/${tag.slug}`}>{tag.label}</a>
							</>
						))}
					</>
				)}
			</div>
		</header>

		{post.data.featured_image && (
			<div class="article-image" {...post.edit.featured_image}>
				<Image image={post.data.featured_image} />
			</div>
		)}

		<div class="article-body" {...post.edit.content}>
			<PortableText value={post.data.content} />
		</div>

		<div class="article-comments">
			<Comments
				collection="posts"
				contentId={post.data.id}
			/>
			<CommentForm
				collection="posts"
				contentId={post.data.id}
			/>
		</div>
	</article>
</Base>

<style>
	.article {
		max-width: 800px;
	}

	.article-header {
		margin-bottom: 1.5rem;
	}

	.article-title {
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-heading);
		margin-bottom: 0.5rem;
	}

	.article-meta {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.article-meta a {
		color: var(--color-accent);
	}

	.meta-sep {
		margin: 0 0.5rem;
		color: var(--color-border);
	}

	.article-image {
		margin-bottom: 1.5rem;
	}

	.article-image img {
		width: 100%;
		height: auto;
	}

	.article-body {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text);
	}

	.article-body :global(h2) {
		font-size: 1.5rem;
		margin: 2rem 0 1rem;
	}

	.article-body :global(h3) {
		font-size: 1.25rem;
		margin: 1.5rem 0 0.75rem;
	}

	.article-body :global(p) {
		margin-bottom: 1rem;
	}

	.article-body :global(ul),
	.article-body :global(ol) {
		margin: 0 0 1rem 1.5rem;
	}

	.article-body :global(li) {
		margin-bottom: 0.5rem;
	}

	.article-body :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding-left: 1rem;
		margin: 1rem 0;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.article-body :global(img) {
		max-width: 100%;
		height: auto;
		margin: 1rem 0;
	}

	.article-body :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
	}

	.article-comments {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}
</style>
