---
import { getMenu, getSiteSettings } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	/** Show right sidebar (default: false) */
	sidebar?: boolean;
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	sidebar = false,
} = Astro.props;

const settings = await getSiteSettings();
const siteTitle = settings?.title || "Klipperhotell";
const siteTagline = settings?.tagline || "Vi lagrer din robotklipper - en del av Mortenshage.no";
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const menu = await getMenu("primary");

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;

const navItems = menu?.items ?? [
	{ label: "Hjem", url: "/", target: null },
	{ label: "Klipperhotell & vinterservice 2023/24", url: "/pages/vinterservice-klipperhotell", target: null },
	{ label: "Om", url: "/pages/om", target: null },
	{ label: "Blogg", url: "/posts", target: null },

	{ label: "Kontakt oss", url: "/pages/kontakt-oss", target: null },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="nb">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<div class="header-inner">
				<div class="header-left">
					<h1 class="site-title"><a href="/">{siteTitle}</a></h1>
					<p class="site-tagline">{siteTagline}</p>
				</div>
				<div class="header-right">
					<form action="/search" method="get" class="header-search">
						<input type="text" name="q" placeholder="Søk..." class="header-search-input" />
						<button type="submit" class="header-search-btn" aria-label="Søk">🔍</button>
					</form>
					<nav class="main-nav">
						<button class="menu-toggle" aria-label="Menu" aria-expanded="false">
							☰ Menu
						</button>
						<ul class="nav-menu" id="nav-menu">
							{navItems.map((item) => (
								<li class={currentPath === item.url ? "active" : ""}>
									<a href={item.url} target={item.target}>{item.label}</a>
								</li>
							))}
							{isLoggedIn && (
								<li>
									<a href="/_emdash/admin" class="nav-admin">Admin</a>
								</li>
							)}
						</ul>
					</nav>
				</div>
			</div>
		</header>

		<div class="page-wrapper">
			{sidebar ? (
				<div class="content-with-sidebar">
					<main class="site-content">
						<slot />
					</main>
					<aside class="sidebar">
						<div class="widget">
							<h3 class="widget-title">Søk</h3>
							<form action="/search" method="get" class="search-form">
								<input type="text" name="q" placeholder="Søk..." class="search-input" />
								<button type="submit" class="search-btn">🔍</button>
							</form>
						</div>
						<div class="widget">
							<h3 class="widget-title">Arkiver</h3>
							<ul class="widget-list">
								<li><a href="/posts">Alle innlegg</a></li>
							</ul>
						</div>
						<WidgetArea name="sidebar" />
					</aside>
				</div>
			) : (
				<main class="site-content">
					<slot />
				</main>
			)}
		</div>

		<footer class="site-footer">
			<div class="footer-widgets">
				<div class="footer-inner-grid">
					<div class="footer-col">
						<h4>Finn oss</h4>
						<p>Adresse:</p>
						<p>Stensrudvegen 5A<br />2335 Stange</p>
						<p>Telefon: 97 800 800</p>
						<p>Morten: 45 45 35 84</p>
						<p><a href="mailto:post@klipperhotell.no">post@klipperhotell.no</a></p>
					</div>
					<div class="footer-col">
						<h4>Søk</h4>
						<form action="/search" method="get" class="footer-search">
							<input type="text" name="q" placeholder="Søk..." />
						</form>
						<h4 class="mt">Om Klipperhotell</h4>
						<p>Sjekk også ut <a href="https://www.mortenshage.no">Mortenshage.no</a> for mer informasjon.</p>
					</div>
					<div class="footer-col">
						<h4>Se også</h4>
						<p><a href="https://www.mortenshage.no">mortenshage.no</a></p>
					</div>
					<div class="footer-col">
						<h4>Hvorfor vinterservice?</h4>
						<p>Jo, fordi det er viktig for at din robotgressklipper skal fungere bra i mange år!</p>
						<p><a href="/pages/hvorfor-vinterservice">Les mer</a></p>
					</div>
				</div>
			</div>
			<div class="footer-socket">
				<div class="footer-socket-inner">
					<p class="copyright">
						Copyright &copy; 2026 {siteTitle}. All rights reserved.
						Powered by <a href="https://emdashcms.com">EmDash</a>.
					</p>
					<nav class="footer-nav">
						{navItems.slice(1).map((item) => (
							<a href={item.url}>{item.label}</a>
						))}
					</nav>
				</div>
			</div>
		</footer>

		<script>
			const toggle = document.querySelector('.menu-toggle');
			const menu = document.getElementById('nav-menu');
			if (toggle && menu) {
				toggle.addEventListener('click', () => {
					const expanded = toggle.getAttribute('aria-expanded') === 'true';
					toggle.setAttribute('aria-expanded', String(!expanded));
					menu.classList.toggle('open');
				});
			}
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			body, h1, h2, h3, h4, h5, h6, p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}

			ul, ol { padding: 0; }

			html { scroll-behavior: smooth; }

			body {
				font-family: var(--font-sans);
				font-size: 16px;
				line-height: 1.8;
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				min-height: 100vh;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: var(--color-accent);
				text-decoration: none;
				transition: color 0.2s;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
				color: var(--color-accent-hover);
			}

			img { max-width: 100%; height: auto; display: block; }

			h1, h2, h3, h4, h5, h6 {
				font-family: var(--font-sans);
				line-height: 1.2;
				font-weight: 700;
				color: var(--color-heading);
			}

			h1 { font-size: 30px; }
			h2 { font-size: 28px; }
			h3 { font-size: 26px; }
			h4 { font-size: 24px; }

			::selection { background: var(--color-accent); color: white; }
		</style>

		<style>
			/* ── Header ─────────────────────── */
			.site-header {
				background: #f8f8f8;
				border-bottom: 1px solid #eaeaea;
			}

			.header-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 1.5rem 25px;
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
			}

			.site-title {
				font-size: 30px;
				font-weight: 900;
				margin: 0;
				line-height: 1.2;
			}

			.site-title a {
				color: var(--color-heading);
				text-decoration: none;
			}

			.site-title a:hover {
				color: var(--color-accent);
			}

			.site-tagline {
				font-size: 13px;
				color: #999;
				margin-top: 4px;
				font-style: italic;
			}

			.header-right {
				text-align: right;
				padding-top: 0.25rem;
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 6px;
			}

			.header-search {
				display: flex;
			}

			.header-search-input {
				padding: 5px 8px;
				border: 1px solid #ddd;
				font-family: var(--font-sans);
				font-size: 13px;
				width: 160px;
			}

			.header-search-btn {
				padding: 5px 10px;
				background: var(--color-accent);
				border: none;
				color: white;
				cursor: pointer;
				font-size: 13px;
				line-height: 1;
			}

			/* ── Navigation ─────────────────── */
			.main-nav {
			}

			.menu-toggle {
				display: none;
				background: var(--color-accent);
				border: none;
				color: white;
				font-family: var(--font-sans);
				font-size: 14px;
				padding: 8px 16px;
				cursor: pointer;
			}

			.nav-menu {
				display: flex;
				list-style: none;
				margin: 0;
				padding: 0;
				gap: 0;
			}

			.nav-menu li a {
				display: inline-block;
				padding: 4px 12px;
				color: #444;
				text-decoration: none;
				font-size: 14px;
				font-weight: 400;
				transition: color 0.2s;
			}

			.nav-menu li a:hover,
			.nav-menu li.active a {
				color: var(--color-accent);
			}

			.nav-admin {
				opacity: 0.5;
				font-size: 12px !important;
			}

			/* ── Page wrapper ────────────────── */
			.page-wrapper {
				max-width: var(--wide-width);
				margin: 0 auto;
				background: var(--color-page);
			}

			.site-content {
				padding: 30px 25px;
			}

			/* ── Sidebar layout ──────────────── */
			.content-with-sidebar {
				display: flex;
				gap: 40px;
				padding: 0 25px;
			}

			.content-with-sidebar .site-content {
				flex: 1;
				min-width: 0;
				padding: 30px 0;
			}

			.sidebar {
				flex: 0 0 300px;
				padding: 30px 0;
			}

			.widget {
				margin-bottom: 2rem;
			}

			.widget-title {
				font-size: 20px;
				font-weight: 700;
				color: var(--color-heading);
				margin-bottom: 0.75rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid var(--color-accent);
			}

			.widget-list {
				list-style: none;
			}

			.widget-list li {
				padding: 4px 0;
			}

			.widget-list a {
				color: var(--color-accent);
				font-size: 14px;
			}

			.search-form {
				display: flex;
			}

			.search-input {
				flex: 1;
				padding: 6px 10px;
				border: 1px solid #ddd;
				font-family: var(--font-sans);
				font-size: 14px;
			}

			.search-btn {
				padding: 6px 12px;
				background: var(--color-accent);
				border: none;
				color: white;
				cursor: pointer;
				font-size: 14px;
			}

			/* ── Footer ─────────────────────── */
			.site-footer {
				margin-top: 0;
			}

			.footer-widgets {
				background: #333;
				padding: 30px 0;
			}

			.footer-inner-grid {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 25px;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 30px;
			}

			.footer-col h4 {
				color: #fff;
				font-size: 18px;
				font-weight: 700;
				margin-bottom: 12px;
				padding-bottom: 8px;
				border-bottom: 2px solid var(--color-accent);
			}

			.footer-col h4.mt {
				margin-top: 1.5rem;
			}

			.footer-col p,
			.footer-col li {
				color: #999;
				font-size: 14px;
				line-height: 1.8;
			}

			.footer-col ul {
				list-style: none;
			}

			.footer-col a {
				color: var(--color-accent);
			}

			.footer-col a:hover {
				color: #fff;
			}

			.footer-search input {
				width: 100%;
				padding: 6px 10px;
				border: 1px solid #555;
				background: #444;
				color: #ddd;
				font-family: var(--font-sans);
				font-size: 14px;
			}

			.footer-socket {
				background: #f8f8f8;
				padding: 12px 0;
				border-top: 1px solid #eaeaea;
			}

			.footer-socket-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 25px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: 8px;
			}

			.copyright {
				font-size: 13px;
				color: #666;
				margin: 0;
			}

			.copyright a {
				color: var(--color-accent);
			}

			.footer-nav {
				display: flex;
				gap: 16px;
			}

			.footer-nav a {
				color: #666;
				font-size: 13px;
			}

			.footer-nav a:hover {
				color: var(--color-accent);
			}

			/* ── Sidebar widgets from EmDash ── */
			.sidebar :global(.widget-area) {
				display: block;
			}

			.sidebar :global(.widget__title) {
				font-size: 20px;
				font-weight: 700;
				color: var(--color-heading);
				margin-bottom: 0.75rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid var(--color-accent);
			}

			/* ── Responsive ──────────────────── */
			@media (max-width: 768px) {
				.header-inner {
					flex-direction: column;
				}

				.header-right {
					width: 100%;
					text-align: left;
					padding-top: 0.75rem;
				}

				.menu-toggle {
					display: inline-block;
				}

				.nav-menu {
					display: none;
					flex-direction: column;
					width: 100%;
					margin-top: 0.5rem;
				}

				.nav-menu.open {
					display: flex;
				}

				.nav-menu li a {
					padding: 8px 0;
					display: block;
					border-top: 1px solid #eaeaea;
				}

				.content-with-sidebar {
					flex-direction: column;
				}

				.sidebar {
					flex: none;
					border-top: 1px solid #eaeaea;
					padding-top: 1.5rem;
				}

				.footer-inner-grid {
					grid-template-columns: 1fr;
				}

				.footer-socket-inner {
					flex-direction: column;
					text-align: center;
				}

				.footer-nav {
					flex-wrap: wrap;
					justify-content: center;
				}
			}
		</style>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
