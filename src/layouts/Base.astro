---
import { getMenu, getEmDashCollection, getSiteSettings } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;

const settings = await getSiteSettings();
const siteTitle = settings?.title || "Klipperhotell";
const siteTagline = settings?.tagline || "Vi lagrer din robotklipper - en del av Mortenshage.no";
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const menu = await getMenu("primary");
const { entries: pages } = await getEmDashCollection("pages");

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;

// Default nav items if no menu configured yet
const navItems = menu?.items ?? [
	{ label: "Hjem", url: "/", target: null },
	{ label: "Vinterservice 2023/24", url: "/pages/vinterservice-klipperhotell", target: null },
	{ label: "Hvorfor vinterservice?", url: "/pages/hvorfor-vinterservice", target: null },
	{ label: "Om", url: "/pages/om", target: null },
	{ label: "Blog", url: "/posts", target: null },
	{ label: "Kontakt oss", url: "/pages/kontakt-oss", target: null },
];
---

<!doctype html>
<html lang="nb">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<div class="header-top">
				<div class="header-inner">
					<div class="site-branding">
						<a href="/" class="site-title">{siteTitle}</a>
						<p class="site-tagline">{siteTagline}</p>
					</div>
				</div>
			</div>
			<nav class="main-nav">
				<div class="nav-inner">
					<button class="menu-toggle" aria-label="Menu" aria-expanded="false">
						<span class="menu-icon"></span>
						Menu
					</button>
					<ul class="nav-menu" id="nav-menu">
						{navItems.map((item) => (
							<li>
								<a href={item.url} target={item.target}>{item.label}</a>
							</li>
						))}
						{isLoggedIn && (
							<li>
								<a href="/_emdash/admin" class="nav-admin">Admin</a>
							</li>
						)}
					</ul>
				</div>
			</nav>
		</header>

		<div class="page-wrapper">
			<main class="site-content">
				<slot />
			</main>
		</div>

		<footer class="site-footer">
			<div class="footer-widgets">
				<div class="footer-inner">
					<div class="footer-col">
						<h4>Om {siteTitle}</h4>
						<p>{siteTagline}</p>
					</div>
					<div class="footer-col">
						<h4>Navigasjon</h4>
						<ul>
							{navItems.slice(0, 5).map((item) => (
								<li><a href={item.url}>{item.label}</a></li>
							))}
						</ul>
					</div>
					<div class="footer-col">
						<h4>Kontakt</h4>
						<p>Telefon: 97 800 800</p>
						<p>Epost: post@klipperhotell.no</p>
						<WidgetArea name="footer" />
					</div>
				</div>
			</div>
			<div class="footer-socket">
				<div class="footer-inner">
					<p>
						Powered by <a href="https://emdashcms.com">EmDash</a>
						&nbsp;|&nbsp; En del av <a href="https://www.mortenshage.no">Mortenshage.no</a>
					</p>
				</div>
			</div>
		</footer>

		<script>
			// Mobile menu toggle
			const toggle = document.querySelector('.menu-toggle');
			const menu = document.getElementById('nav-menu');
			if (toggle && menu) {
				toggle.addEventListener('click', () => {
					const expanded = toggle.getAttribute('aria-expanded') === 'true';
					toggle.setAttribute('aria-expanded', String(!expanded));
					menu.classList.toggle('open');
				});
			}
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			body, h1, h2, h3, h4, h5, h6, p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}

			ul, ol { padding: 0; }

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: var(--leading-relaxed);
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				min-height: 100vh;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: var(--color-accent);
				text-decoration: none;
				transition: color 0.2s;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
				color: var(--color-accent-hover);
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1, h2, h3, h4, h5, h6 {
				font-family: var(--font-sans);
				line-height: var(--leading-tight);
				font-weight: 700;
				color: var(--color-heading);
			}

			::selection {
				background: var(--color-accent);
				color: white;
			}
		</style>

		<style>
			/* ── Header ─────────────────────── */
			.header-top {
				background: var(--color-page);
				padding: 1.5rem 0;
			}

			.header-inner, .nav-inner, .footer-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.site-branding {
				text-align: left;
			}

			.site-title {
				font-size: 2rem;
				font-weight: 900;
				color: var(--color-heading);
				text-decoration: none;
				letter-spacing: -0.02em;
			}

			.site-title:hover {
				color: var(--color-accent);
			}

			.site-tagline {
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				margin-top: 0.25rem;
				font-style: italic;
			}

			/* ── Navigation ─────────────────── */
			.main-nav {
				background: var(--color-accent);
			}

			.nav-inner {
				display: flex;
				align-items: stretch;
			}

			.menu-toggle {
				display: none;
				background: none;
				border: none;
				color: white;
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				padding: 0.75rem 1rem;
				cursor: pointer;
				align-items: center;
				gap: 0.5rem;
			}

			.menu-icon {
				display: inline-block;
				width: 18px;
				height: 2px;
				background: white;
				position: relative;
			}

			.menu-icon::before,
			.menu-icon::after {
				content: '';
				position: absolute;
				width: 100%;
				height: 2px;
				background: white;
				left: 0;
			}

			.menu-icon::before { top: -6px; }
			.menu-icon::after { top: 6px; }

			.nav-menu {
				display: flex;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.nav-menu li a {
				display: block;
				padding: 0.75rem 1rem;
				color: white;
				text-decoration: none;
				font-size: var(--font-size-sm);
				font-weight: 400;
				transition: background 0.2s;
			}

			.nav-menu li a:hover {
				background: rgba(0, 0, 0, 0.15);
				color: white;
			}

			.nav-admin {
				opacity: 0.7;
			}

			/* ── Page wrapper ────────────────── */
			.page-wrapper {
				max-width: var(--wide-width);
				margin: 0 auto;
				background: var(--color-page);
				min-height: 60vh;
			}

			.site-content {
				padding: 2rem 1.5rem;
			}

			/* ── Footer ─────────────────────── */
			.site-footer {
				margin-top: 0;
			}

			.footer-widgets {
				background: var(--color-footer-bg);
				padding: 2.5rem 0;
			}

			.footer-widgets .footer-inner {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}

			.footer-col h4 {
				color: var(--color-footer-heading);
				font-size: var(--font-size-lg);
				font-weight: 700;
				margin-bottom: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.footer-col p,
			.footer-col li {
				color: var(--color-footer-text);
				font-size: var(--font-size-sm);
				line-height: 1.8;
			}

			.footer-col ul {
				list-style: none;
			}

			.footer-col a {
				color: var(--color-footer-text);
				text-decoration: none;
				transition: color 0.2s;
			}

			.footer-col a:hover {
				color: var(--color-accent);
			}

			.footer-col :global(.widget-area) {
				display: block;
			}

			.footer-col :global(.widget__title) {
				color: var(--color-footer-heading);
				font-size: var(--font-size-base);
				margin-top: 1rem;
				margin-bottom: 0.5rem;
			}

			.footer-col :global(.widget__content) {
				color: var(--color-footer-text);
				font-size: var(--font-size-sm);
			}

			.footer-socket {
				background: var(--color-footer-socket-bg);
				padding: 1rem 0;
				text-align: center;
			}

			.footer-socket p {
				color: var(--color-footer-text);
				font-size: var(--font-size-sm);
				margin: 0;
			}

			.footer-socket a {
				color: var(--color-accent);
			}

			/* ── Responsive ──────────────────── */
			@media (max-width: 768px) {
				.menu-toggle {
					display: flex;
				}

				.nav-inner {
					flex-direction: column;
				}

				.nav-menu {
					display: none;
					flex-direction: column;
				}

				.nav-menu.open {
					display: flex;
				}

				.nav-menu li a {
					padding: 0.75rem 1.5rem;
					border-top: 1px solid rgba(255, 255, 255, 0.1);
				}

				.footer-widgets .footer-inner {
					grid-template-columns: 1fr;
				}

				.site-title {
					font-size: 1.5rem;
				}
			}
		</style>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
