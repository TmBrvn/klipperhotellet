---
import { getMenu, getSiteSettings } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	sidebar?: boolean;
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	sidebar = false,
} = Astro.props;

const settings = await getSiteSettings();
const siteTitle = settings?.title || "Klipperhotell";
const siteTagline = settings?.tagline || "Vi lagrer din robotklipper - en del av Mortenshage.no";
const fullTitle = title.includes(siteTitle) ? title : `${title} - ${siteTitle}`;

const menu = await getMenu("primary");

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;

const navItems = menu?.items ?? [
	{ label: "Hjem", url: "/", target: null },
	{ label: "Klipperhotell & vinterservice 2023/24", url: "/pages/vinterservice-klipperhotell", target: null },
	{ label: "Om", url: "/pages/om", target: null },
	{ label: "Blogg", url: "/posts", target: null },
	{ label: "Kontakt oss", url: "/pages/kontakt-oss", target: null },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="nb">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<div class="header-inner">
				<div class="header-left">
					<a href="/" class="site-title">{siteTitle}</a>
					<p class="site-tagline">{siteTagline}</p>
				</div>
				<div class="header-right">
					<form action="/search" method="get" class="header-search">
						<input type="text" name="q" placeholder="Søk..." class="header-search-input" />
						<button type="submit" class="header-search-btn" aria-label="Søk">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
						</button>
					</form>
					<nav class="main-nav">
						<button class="menu-toggle" id="menu-toggle" aria-label="Meny" aria-expanded="false">
							<svg class="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
							<svg class="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
							<span>Meny</span>
						</button>
						<ul class="nav-menu" id="nav-menu">
							{navItems.map((item) => (
								<li class={currentPath === item.url || (item.url !== "/" && currentPath.startsWith(item.url)) ? "active" : ""}>
									<a href={item.url} target={item.target}>{item.label}</a>
								</li>
							))}
							{isLoggedIn && (
								<li><a href="/_emdash/admin" class="nav-admin-link">Admin</a></li>
							)}
						</ul>
					</nav>
				</div>
			</div>
		</header>

		<div class="page-wrapper">
			{sidebar ? (
				<div class="content-with-sidebar">
					<main class="site-content">
						<slot />
					</main>
					<aside class="sidebar">
						<div class="widget">
							<h3 class="widget-title">Søk</h3>
							<form action="/search" method="get" class="search-form">
								<input type="text" name="q" placeholder="Søk..." class="search-input" />
								<button type="submit" class="search-btn" aria-label="Søk">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
								</button>
							</form>
						</div>
						<div class="widget">
							<h3 class="widget-title">Arkiver</h3>
							<ul class="widget-list">
								<li><a href="/posts">Alle innlegg</a></li>
							</ul>
						</div>
						<WidgetArea name="sidebar" />
					</aside>
				</div>
			) : (
				<main class="site-content">
					<slot />
				</main>
			)}
		</div>

		<footer class="site-footer">
			<div class="footer-widgets">
				<div class="footer-grid">
					<div class="footer-col">
						<h4>Finn oss</h4>
						<p>Adresse:</p>
						<p>Stensrudvegen 5A<br/>2335 Stange</p>
						<p>Telefon: 97 800 800</p>
						<p>Morten: 45 45 35 84</p>
						<p><a href="mailto:post@klipperhotell.no">post@klipperhotell.no</a></p>
					</div>
					<div class="footer-col">
						<h4>Søk</h4>
						<form action="/search" method="get" class="footer-search">
							<input type="text" name="q" placeholder="Søk..." />
						</form>
						<h4 class="mt">Om Klipperhotell</h4>
						<p>Sjekk også ut <a href="https://www.mortenshage.no">Mortenshage.no</a> for mer informasjon.</p>
					</div>
					<div class="footer-col">
						<h4>Se også</h4>
						<p><a href="https://www.mortenshage.no">mortenshage.no</a></p>
					</div>
					<div class="footer-col">
						<h4>Hvorfor vinterservice?</h4>
						<p>Jo, fordi det er viktig for at din robotgressklipper skal fungere bra i mange år!</p>
						<p><a href="/pages/hvorfor-vinterservice">Les mer</a></p>
					</div>
				</div>
			</div>
			<div class="footer-socket">
				<div class="footer-socket-inner">
					<p class="copyright">Copyright &copy; 2026 {siteTitle}. Powered by <a href="https://emdashcms.com">EmDash</a>.</p>
					<nav class="footer-nav">
						{navItems.slice(1).map((item) => (
							<a href={item.url}>{item.label}</a>
						))}
					</nav>
				</div>
			</div>
		</footer>

		<script>
			const toggle = document.getElementById('menu-toggle');
			const menu = document.getElementById('nav-menu');
			if (toggle && menu) {
				toggle.addEventListener('click', () => {
					const expanded = toggle.getAttribute('aria-expanded') === 'true';
					toggle.setAttribute('aria-expanded', String(!expanded));
					menu.classList.toggle('open');
					toggle.classList.toggle('is-open');
				});
			}
		</script>

		<style is:global>
			*, *::before, *::after { box-sizing: border-box; }
			body, h1, h2, h3, h4, h5, h6, p, ul, ol, figure, blockquote, dl, dd { margin: 0; }
			ul, ol { padding: 0; }

			html {
				scroll-behavior: smooth;
				-webkit-text-size-adjust: 100%;
			}

			body {
				font-family: var(--font-sans);
				font-size: 16px;
				line-height: 1.7;
				color: var(--color-text);
				background: var(--color-bg);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: var(--color-accent);
				text-decoration: none;
				transition: color var(--transition);
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
				color: var(--color-accent-hover);
			}

			img { max-width: 100%; height: auto; display: block; }

			h1, h2, h3, h4, h5, h6 {
				font-family: var(--font-sans);
				line-height: 1.25;
				font-weight: 700;
				color: var(--color-heading);
			}

			h1 { font-size: 28px; }
			h2 { font-size: 26px; }
			h3 { font-size: 22px; }
			h4 { font-size: 20px; }

			::selection { background: var(--color-accent); color: white; }
		</style>

		<style>
			/* ── Header ─────────────────────── */
			.site-header {
				background: var(--color-page);
				border-bottom: 1px solid var(--color-border-subtle);
				box-shadow: var(--shadow-card);
				position: sticky;
				top: 0;
				z-index: 100;
			}

			.header-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 1rem 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.site-title {
				font-size: 28px;
				font-weight: 900;
				color: var(--color-heading);
				text-decoration: none;
				letter-spacing: -0.02em;
				transition: color var(--transition);
			}

			.site-title:hover { color: var(--color-accent); }

			.site-tagline {
				font-size: 12px;
				color: var(--color-muted);
				margin-top: 2px;
				font-style: italic;
			}

			.header-right {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 6px;
			}

			.header-search {
				display: flex;
			}

			.header-search-input {
				padding: 6px 10px;
				border: 1px solid var(--color-border);
				border-right: none;
				border-radius: var(--radius-sm) 0 0 var(--radius-sm);
				font-family: var(--font-sans);
				font-size: 13px;
				width: 160px;
				outline: none;
				transition: border-color var(--transition);
			}

			.header-search-input:focus {
				border-color: var(--color-accent);
			}

			.header-search-btn {
				padding: 6px 10px;
				background: var(--color-accent);
				border: 1px solid var(--color-accent);
				border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
				color: white;
				cursor: pointer;
				display: flex;
				align-items: center;
				transition: background var(--transition);
			}

			.header-search-btn:hover {
				background: var(--color-accent-hover);
			}

			/* ── Navigation ─────────────────── */
			.menu-toggle {
				display: none;
				background: var(--color-accent);
				border: none;
				color: white;
				font-family: var(--font-sans);
				font-size: 14px;
				padding: 8px 16px;
				cursor: pointer;
				border-radius: var(--radius-sm);
				align-items: center;
				gap: 6px;
				transition: background var(--transition);
			}

			.menu-toggle:hover { background: var(--color-accent-hover); }
			.menu-icon-close { display: none; }
			.menu-toggle.is-open .menu-icon-open { display: none; }
			.menu-toggle.is-open .menu-icon-close { display: block; }

			.nav-menu {
				display: flex;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.nav-menu li a {
				display: inline-block;
				padding: 4px 10px;
				color: var(--color-text-secondary);
				text-decoration: none;
				font-size: 14px;
				transition: color var(--transition);
			}

			.nav-menu li a:hover,
			.nav-menu li.active a {
				color: var(--color-accent);
			}

			.nav-admin-link { opacity: 0.4; font-size: 12px !important; }

			/* ── Page wrapper ────────────────── */
			.page-wrapper {
				max-width: var(--wide-width);
				margin: 0 auto;
				background: var(--color-page);
				box-shadow: var(--shadow-card);
				flex: 1;
				width: 100%;
			}

			.site-content {
				padding: 2rem 1.5rem;
			}

			/* ── Sidebar layout ──────────────── */
			.content-with-sidebar {
				display: flex;
				gap: 2.5rem;
				padding: 0 1.5rem;
			}

			.content-with-sidebar .site-content {
				flex: 1;
				min-width: 0;
				padding: 2rem 0;
			}

			.sidebar {
				flex: 0 0 280px;
				padding: 2rem 0;
			}

			.widget { margin-bottom: 2rem; }

			.widget-title {
				font-size: 18px;
				font-weight: 700;
				color: var(--color-heading);
				margin-bottom: 0.75rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid var(--color-accent);
			}

			.widget-list { list-style: none; }
			.widget-list li { padding: 4px 0; }
			.widget-list a { color: var(--color-accent); font-size: 14px; }

			.search-form { display: flex; }

			.search-input {
				flex: 1;
				padding: 8px 12px;
				border: 1px solid var(--color-border);
				border-right: none;
				border-radius: var(--radius-sm) 0 0 var(--radius-sm);
				font-family: var(--font-sans);
				font-size: 14px;
				outline: none;
				transition: border-color var(--transition);
			}

			.search-input:focus { border-color: var(--color-accent); }

			.search-btn {
				padding: 8px 12px;
				background: var(--color-accent);
				border: 1px solid var(--color-accent);
				border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
				color: white;
				cursor: pointer;
				display: flex;
				align-items: center;
				transition: background var(--transition);
			}

			.search-btn:hover { background: var(--color-accent-hover); }

			/* ── Footer ─────────────────────── */
			.site-footer { margin-top: auto; }

			.footer-widgets {
				background: var(--color-footer-bg);
				padding: 2.5rem 0;
			}

			.footer-grid {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 1.5rem;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
			}

			.footer-col h4 {
				color: var(--color-footer-heading);
				font-size: 16px;
				font-weight: 700;
				margin-bottom: 12px;
				padding-bottom: 8px;
				border-bottom: 2px solid var(--color-accent);
			}

			.footer-col h4.mt { margin-top: 1.5rem; }

			.footer-col p, .footer-col li {
				color: var(--color-footer-text);
				font-size: 14px;
				line-height: 1.8;
			}

			.footer-col ul { list-style: none; }

			.footer-col a { color: var(--color-accent); transition: color var(--transition); }
			.footer-col a:hover { color: #fff; }

			.footer-search input {
				width: 100%;
				padding: 8px 12px;
				border: 1px solid #555;
				background: #3a3a3a;
				color: #ddd;
				font-family: var(--font-sans);
				font-size: 14px;
				border-radius: var(--radius-sm);
				outline: none;
				transition: border-color var(--transition);
			}

			.footer-search input:focus { border-color: var(--color-accent); }

			.footer-socket {
				background: #f8f8f8;
				padding: 12px 0;
				border-top: 1px solid var(--color-border-subtle);
			}

			.footer-socket-inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: 0 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: 8px;
			}

			.copyright { font-size: 13px; color: #888; margin: 0; }
			.copyright a { color: var(--color-accent); }

			.footer-nav { display: flex; gap: 16px; flex-wrap: wrap; }
			.footer-nav a { color: #888; font-size: 13px; transition: color var(--transition); }
			.footer-nav a:hover { color: var(--color-accent); }

			/* ── Sidebar EmDash widgets ──────── */
			.sidebar :global(.widget-area) { display: block; }
			.sidebar :global(.widget__title) {
				font-size: 18px; font-weight: 700; color: var(--color-heading);
				margin-bottom: 0.75rem; padding-bottom: 0.5rem;
				border-bottom: 2px solid var(--color-accent);
			}

			/* ── Mobile ──────────────────────── */
			@media (max-width: 900px) {
				.content-with-sidebar {
					flex-direction: column;
					gap: 0;
				}

				.sidebar {
					flex: none;
					border-top: 1px solid var(--color-border);
					padding-top: 1.5rem;
				}
			}

			@media (max-width: 768px) {
				.header-inner {
					flex-direction: column;
					align-items: stretch;
					gap: 0.75rem;
					padding: 0.75rem 1rem;
				}

				.header-left {
					display: flex;
					justify-content: space-between;
					align-items: center;
				}

				.site-title { font-size: 22px; }
				.site-tagline { display: none; }

				.header-right {
					flex-direction: row;
					align-items: center;
					justify-content: space-between;
					gap: 8px;
				}

				.header-search { flex: 1; }
				.header-search-input { width: 100%; }

				.menu-toggle {
					display: flex;
					flex-shrink: 0;
				}

				.nav-menu {
					display: none;
					flex-direction: column;
					position: absolute;
					top: 100%;
					left: 0;
					right: 0;
					background: var(--color-page);
					box-shadow: var(--shadow-elevated);
					z-index: 200;
				}

				.nav-menu.open { display: flex; }

				.nav-menu li a {
					display: block;
					padding: 12px 1.5rem;
					border-bottom: 1px solid var(--color-border-subtle);
					font-size: 15px;
				}

				.nav-menu li:last-child a { border-bottom: none; }

				.site-header { position: relative; }

				.site-content { padding: 1.25rem 1rem; }
				.content-with-sidebar { padding: 0 1rem; }

				.footer-grid {
					grid-template-columns: 1fr 1fr;
					gap: 1.5rem;
					padding: 0 1rem;
				}

				.footer-socket-inner {
					flex-direction: column;
					text-align: center;
					padding: 0 1rem;
				}

				.footer-nav { justify-content: center; }
			}

			@media (max-width: 480px) {
				.footer-grid { grid-template-columns: 1fr; }

				.header-right {
					flex-direction: column;
					align-items: stretch;
				}

				.header-search { order: 2; }
				.menu-toggle { order: 1; align-self: flex-end; }
			}
		</style>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
